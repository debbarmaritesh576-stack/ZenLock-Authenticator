            android:targetPackage="com.aegis.pdf"
            android:targetClass="com.aegis.pdf.MainActivity">
            <extra android:name="tool" android:value="scan"/>
        </intent>
    </shortcut>
    <shortcut
        android:shortcutId="compress"
        android:enabled="true"
        android:icon="@drawable/ic_compress"
        android:shortcutShortLabel="@string/compress_pdf"
        android:shortcutLongLabel="@string/compress_pdf">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="com.aegis.pdf"
            android:targetClass="com.aegis.pdf.MainActivity">
            <extra android:name="tool" android:value="compress"/>
        </intent>
